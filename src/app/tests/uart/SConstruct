import sys
sys.path.insert(0, "../../../util")
from build_tools import *

# UART driver uses USART hardware, so skip ATtiny (USI-only). Include
# stm32g431x8 explicitly — that's the chip on the hardware test jig.
platforms = canary_platforms(
    include_attiny=False,
    extras=[ArmStmPlatform("stm32g431x8")],
)

for testprog in ["recv", "send", "charecho", "lineecho", "linecounter"]:
    RulosBuildTarget(
        name = testprog,
        sources = [f"{testprog}.c"],
        platforms = platforms,
        peripherals = ["uart"],
        extra_cflags = [
            "-DLOG_TO_SERIAL",
            "-DSCHEDULER_CAPACITY=4",
            "-DUART_TX_QUEUE_LEN=256",
            "-DUART_RX_QUEUE_LEN=256",
            "-DLINEREADER_MAX_LINE_LEN=512",
        ],
    ).build()
