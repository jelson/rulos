#!/bin/sh
#
# autoformat: clang-format RULOS C/C++ source to the repo .clang-format style.
#
#   autoformat          format just the .c/.h/.cpp files changed in git
#                       (a quick "fix what I just touched")
#   autoformat --all    format every .c/.h/.cpp under src/, except the
#                       vendored and generated files listed in EXCLUDE below
#
# Third-party code that RULOS vendors lives under ext/, which is outside src/,
# so --all never touches it. EXCLUDE covers the stragglers that still live
# under src/: vendor files kept close to upstream (reformatting them buries the
# local changes in whitespace and ruins diffs against the original) and
# machine-generated files (overwritten on the next build anyway).

# Repo-relative extended-regexes, one per line. '#' lines are comments.
EXCLUDE='
# vendored / third-party, kept near upstream for readable diffs
src/lib/chip/arm/lpc/periph/twi/i2c_11xx\.[ch]$
src/lib/chip/arm/stm32/stm32(c0|f0|f1|f3|g0|g4)xx_hal_conf\.h$
src/lib/chip/arm/stm32/periph/usb_cdc/usbd_conf\.c$
src/lib/chip/arm/stm32/periph/usb_cdc/usbd_desc\.[ch]$
src/lib/graveyard/linear2ulaw\.[ch]$
# machine-generated (regenerated by the build)
src/lib/chip/.*/autogen-pins-[a-z0-9]+\.h$
'

if [ "$1" = "--all" ]; then
    cd "$(git rev-parse --show-toplevel)" || exit 1
    exclude_re=$(echo "$EXCLUDE" | grep -vE '^[[:space:]]*(#|$)' | paste -sd '|' -)
    filelist=$(find src -type f \( -name '*.c' -o -name '*.h' -o -name '*.cpp' \) \
        | grep -Ev "$exclude_re")
elif [ -n "$1" ]; then
    echo "usage: autoformat [--all]" >&2
    exit 1
else
    filelist=$( { git diff --relative --name-only; \
                  git diff --cached --relative --name-only; } \
                | grep -E '\.(c|h|cpp)$' )
fi

if [ -z "$filelist" ]; then
    echo "No files to format"
    exit
fi

clang-format -i --verbose $filelist
dos2unix $filelist
chmod ugo-x $filelist
